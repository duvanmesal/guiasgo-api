generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TOURIST
  GUIDE
  ADMIN
  SUPPORT
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

model HealthCheck {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  @@map("health_checks")
}

model User {
  id             String               @id @default(uuid())
  email          String               @unique
  passwordHash   String
  fullName       String
  phone          String?
  photoUrl       String?
  status         UserStatus           @default(ACTIVE)
  lastActiveRole UserRole?
  roles          UserRoleAssignment[]
  refreshTokens  RefreshToken[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?

  @@index([status])
  @@map("users")
}

model UserRoleAssignment {
  id         String   @id @default(uuid())
  userId     String
  role       UserRole
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
  @@map("user_roles")
}

model RefreshToken {
  id                String    @id @default(uuid())
  userId            String
  tokenHash         String
  sessionId         String
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  deviceInfo        String?
  ipAddress         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
