generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TOURIST
  GUIDE
  ADMIN
  SUPPORT
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum GuideVerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model HealthCheck {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  @@map("health_checks")
}

model User {
  id             String               @id @default(uuid())
  email          String               @unique
  passwordHash   String
  fullName       String
  phone          String?
  photoUrl       String?
  status         UserStatus           @default(ACTIVE)
  lastActiveRole UserRole?
  roles          UserRoleAssignment[]
  refreshTokens  RefreshToken[]
  touristProfile TouristProfile?
  guideProfile   GuideProfile?
  reviewedCertifications GuideCertification[] @relation("CertificationReviewer")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?

  @@index([status])
  @@map("users")
}

model UserRoleAssignment {
  id         String   @id @default(uuid())
  userId     String
  role       UserRole
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
  @@map("user_roles")
}

model RefreshToken {
  id                String    @id @default(uuid())
  userId            String
  tokenHash         String
  sessionId         String
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  deviceInfo        String?
  ipAddress         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model TouristProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  nationality       String?
  preferredLanguage String?
  emergencyContact  String?
  interests         String[] @default([])
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@map("tourist_profiles")
}

model Country {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("countries")
}

model City {
  id        String         @id @default(uuid())
  countryId String
  name      String
  slug      String
  latitude  Float?
  longitude Float?
  isActive  Boolean        @default(true)
  country   Country        @relation(fields: [countryId], references: [id], onDelete: Restrict)
  guides    GuideProfile[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([countryId, slug])
  @@index([isActive])
  @@map("cities")
}

model Language {
  id        String          @id @default(uuid())
  name      String
  code      String          @unique
  isActive  Boolean         @default(true)
  guides    GuideLanguage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([isActive])
  @@map("languages")
}

model Specialty {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  description String?
  isActive    Boolean          @default(true)
  guides      GuideSpecialty[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([isActive])
  @@map("specialties")
}

model GuideProfile {
  id                 String                    @id @default(uuid())
  userId             String                    @unique
  bio                String
  cityId             String?
  city               String
  languages          String[]                  @default([])
  specialties        String[]                  @default([])
  hourlyRate         Decimal                   @db.Decimal(12, 2)
  supportsHourly     Boolean                   @default(true)
  supportsRoute      Boolean                   @default(false)
  ratingAvg          Decimal                   @default(0) @db.Decimal(3, 2)
  reviewCount        Int                       @default(0)
  isAvailable        Boolean                   @default(false)
  verificationStatus GuideVerificationStatus   @default(PENDING)
  yearsExperience    Int                       @default(0)
  latitude           Float?
  longitude          Float?
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cityCatalog        City?                     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  certifications     GuideCertification[]
  guideLanguages     GuideLanguage[]
  guideSpecialties   GuideSpecialty[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  deletedAt          DateTime?

  @@index([cityId])
  @@index([city])
  @@index([verificationStatus])
  @@index([isAvailable])
  @@map("guide_profiles")
}

model GuideLanguage {
  id         String       @id @default(uuid())
  guideId    String
  languageId String
  level      String?
  guide      GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  language   Language     @relation(fields: [languageId], references: [id], onDelete: Restrict)
  createdAt  DateTime     @default(now())

  @@unique([guideId, languageId])
  @@index([languageId])
  @@map("guide_languages")
}

model GuideSpecialty {
  id          String       @id @default(uuid())
  guideId     String
  specialtyId String
  guide       GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  specialty   Specialty    @relation(fields: [specialtyId], references: [id], onDelete: Restrict)
  createdAt   DateTime     @default(now())

  @@unique([guideId, specialtyId])
  @@index([specialtyId])
  @@map("guide_specialties")
}

model GuideCertification {
  id              String              @id @default(uuid())
  guideId         String
  type            String
  documentUrl     String
  issuedBy        String
  issuedAt        DateTime
  status          CertificationStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  guide           GuideProfile        @relation(fields: [guideId], references: [id], onDelete: Cascade)
  reviewedBy      User?               @relation("CertificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  @@index([guideId])
  @@index([status])
  @@map("guide_certifications")
}
